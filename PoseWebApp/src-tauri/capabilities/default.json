{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "enables the default permissions",
    "windows": [
        "main",
        "menubar",
        "break_alert",
        "break_overlay_0",
        "break_overlay_1",
        "break_overlay_2",
        "break_overlay_3"
    ],
    "permissions": [
        "core:default",
        "sql:allow-execute",
        "sql:allow-select",
        "sql:allow-load",
        "sql:allow-close",
        "dialog:allow-open",
        "dialog:allow-save",
        "notification:default",
        "fs:allow-read-file",
        "fs:allow-write-file",
        "fs:allow-app-write",
        "fs:allow-app-read",
        "fs:allow-appcache-write",
        "fs:allow-appcache-read",
        "autostart:allow-enable",
        "autostart:allow-disable",
        "autostart:allow-is-enabled"
    ]
}
