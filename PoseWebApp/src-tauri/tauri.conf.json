{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "PoseFix",
    "version": "0.1.0",
    "identifier": "com.posefix.dev",
    "build": {
        "frontendDist": "build",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "bun run dev",
        "beforeBuildCommand": "bun run build"
    },
    "app": {
        "windows": [
            {
                "title": "PoseFix",
                "width": 1200,
                "height": 800,
                "resizable": true,
                "fullscreen": false,
                "minHeight": 800,
                "minWidth": 1000
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "macOS": {
            "infoPlist": "Info.plist"
        },
        "resources": {
            "../pose-server/pose_server.py": "pose_server.py",
            "../pose-server/requirements.txt": "requirements.txt"
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
